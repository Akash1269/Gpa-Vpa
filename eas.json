{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      },
      "cache": {
        "key": "dev-v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "image": "latest"
      },
      "cache": {
        "key": "preview-v1"
      },
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx2g -Dorg.gradle.parallel=true -Dorg.gradle.daemon=true -Dorg.gradle.caching=true"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "cache": {
        "key": "prod-v1"
      },
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx2g -Dorg.gradle.parallel=true -Dorg.gradle.daemon=true -Dorg.gradle.caching=true"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
