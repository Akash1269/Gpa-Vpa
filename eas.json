{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "buildArtifactName": "gpa-vpa-dev-v${appVersion}.apk"
      },
      "ios": {
        "simulator": true,
        "buildArtifactName": "gpa-vpa-dev-v${appVersion}.tar.gz"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "buildArtifactName": "gpa-vpa-v${appVersion}.apk"
      },
      "ios": {
        "buildArtifactName": "gpa-vpa-v${appVersion}.ipa"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "buildArtifactName": "gpa-vpa-v${appVersion}.aab"
      },
      "ios": {
        "buildArtifactName": "gpa-vpa-v${appVersion}.ipa"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
